# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# Environnement
.env
.env.*
!.env.example

# Base de données (fichiers runtime — ne pas versionner)
*.db
*.sqlite
*.sqlite3

# Fichiers sensibles
*.gnucash
*.log

# Session Playwright persistée (cookies de session LinkedIn) — ne jamais versionner
browser_profile/
profils_extraits.csv
profils_extraits_email.csv

# Correspondance client (PDF), non destinée à être versionnée
document/compte_rendu/

# IDE
.idea/

# Claude Code — mémoire utilisateur (locale, ne pas versionner)
.claude/memory/*.md
!.claude/memory/MEMORY.md

# Inclure explicitement les settings Claude Code (globalement ignorés)
!.claude/settings.local.json
